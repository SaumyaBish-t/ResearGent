# =============================================================================
# ResearGent — Environment Configuration
# =============================================================================
# Copy this file to `.env` and configure the models YOU want to use.
#
# ResearGent routes every LLM call by CAPABILITY TIER — you bring your own
# provider + model for each tier:
#
#   • REASONING — Planner, Generator, Reflector  (put your strongest model here)
#   • FAST      — Critic, Rewriter               (low-latency / cheap; runs many
#                                                  times per query)
#   • TOOL      — function / structured-output calls
#   • EMBED     — retrieval embeddings           (required for local search)
#
# A "provider" is any OpenAI-compatible endpoint. Built-in provider slots:
#   cerebras · nvidia · groq · openrouter · ollama
# Point any slot's *_BASE_URL at your own OpenAI-compatible server (OpenAI,
# vLLM, LM Studio, a local gateway, …) to use a provider not listed here.
#
# You only need ONE provider to get started: set its API key, choose its
# models, and either let auto-routing pick it or pin the tiers below.
# =============================================================================


# -----------------------------------------------------------------------------
# 1) PROVIDER CREDENTIALS  — set a key for each provider you want to use
# -----------------------------------------------------------------------------
# Fill in only the providers you have keys for; leave the rest blank.

CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=ResearGent

# Ollama is fully local and needs no key — install from https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434/v1


# -----------------------------------------------------------------------------
# 2) MODELS PER TIER  — choose which model each provider uses for each tier
# -----------------------------------------------------------------------------
# Uncomment and set the model strings for whichever provider(s) you configured
# above. Use ANY model that provider offers — your choice.
# Var pattern:  <PROVIDER>_MODEL_<REASONING|FAST|TOOL|EMBED>
# Note: only nvidia / openrouter / ollama can serve the EMBED tier.
#
# (Left commented so the app falls back to its built-in defaults until you
#  explicitly choose. Setting a var to an empty value overrides that default.)

# --- Cerebras ---
# CEREBRAS_MODEL_REASONING=
# CEREBRAS_MODEL_FAST=
# CEREBRAS_MODEL_TOOL=

# --- NVIDIA NIM ---
# NVIDIA_MODEL_REASONING=
# NVIDIA_MODEL_FAST=
# NVIDIA_MODEL_TOOL=
# NVIDIA_MODEL_EMBED=

# --- Groq ---  (Groq does not host embedding models)
# GROQ_MODEL_REASONING=
# GROQ_MODEL_FAST=
# GROQ_MODEL_TOOL=

# --- OpenRouter ---
# OPENROUTER_MODEL_REASONING=
# OPENROUTER_MODEL_FAST=
# OPENROUTER_MODEL_TOOL=
# OPENROUTER_MODEL_EMBED=

# --- Ollama (local) ---  (pull first, e.g. `ollama pull <model>`)
# OLLAMA_MODEL_REASONING=
# OLLAMA_MODEL_FAST=
# OLLAMA_MODEL_TOOL=
# OLLAMA_MODEL_EMBED=


# -----------------------------------------------------------------------------
# 3) TIER ROUTING  — which provider serves each tier
# -----------------------------------------------------------------------------
# Pin a provider per tier. Leave blank to auto-pick the first configured
# provider. Set PRIMARY_PROVIDER to force ONE provider for every tier.
# Valid names: cerebras | nvidia | groq | openrouter | ollama

PRIMARY_PROVIDER=

REASONING_PROVIDER=
FAST_PROVIDER=
TOOL_PROVIDER=
EMBED_PROVIDER=


# -----------------------------------------------------------------------------
# 4) RATE-LIMIT FALLBACKS  (cascade)
# -----------------------------------------------------------------------------
# Free tiers hit 429s. When enabled, a transient failure (429 / 5xx / timeout)
# on one provider automatically retries the SAME tier on the next provider.
CASCADE_FALLBACK_ENABLED=true

# Optional: define an EXACT fallback order per tier (comma-separated provider
# names). This REPLACES the auto-derived chain for that tier — handy to pin a
# specific primary → fallback pairing. Unknown/unconfigured names are ignored.
#
# Example — keep the Critic (FAST tier) responsive by hopping providers on a
# rate limit, and give Reasoning its own chain:
#   FAST_CASCADE=groq,cerebras,openrouter
#   REASONING_CASCADE=nvidia,openrouter,ollama
#   TOOL_CASCADE=groq,cerebras
#
# FAST_CASCADE=
# REASONING_CASCADE=
# TOOL_CASCADE=


# -----------------------------------------------------------------------------
# 5) WEB SEARCH FALLBACK  (when local + academic evidence is insufficient)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=          # optional — agent-tuned web search (https://tavily.com)
SERPER_API_KEY=          # optional — Google SERP (https://serper.dev)
# DuckDuckGo needs no key and is the guaranteed final fallback.
# WEB_SEARCH_CASCADE=tavily,serper,duckduckgo


# -----------------------------------------------------------------------------
# 6) ACADEMIC API  (arXiv + Semantic Scholar paper discovery)
# -----------------------------------------------------------------------------
# Optional — works without a key, just slower. A key removes most 429s.
SEMANTIC_SCHOLAR_API_KEY=


# -----------------------------------------------------------------------------
# 7) KNOWLEDGE BASE  (where cited answers are saved)
# -----------------------------------------------------------------------------
# Folder of plain .md files (works with VS Code, Obsidian, Logseq, vim, …).
# Defaults to ./notes if left blank.
# NOTES_FOLDER_PATH=
OBSIDIAN_OUTPUT_FOLDER=ResearGent

# Auto-save runs that clear the confidence gate.  high | medium | low | always
AUTO_SAVE_TO_NOTES=true
AUTO_SAVE_MIN_CONFIDENCE=medium


# -----------------------------------------------------------------------------
# 8) FRONTEND + TUNABLES  (sensible defaults — override only if needed)
# -----------------------------------------------------------------------------
# Browser origins allowed to call the API (the Next.js dev server is :3000).
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

CRAG_MAX_REWRITES=2                 # query rewrites before web fallback
GRAPH_EXPANSION_ENABLED=true        # 1-hop note-link expansion at retrieval
REFLECTION_MAX_ITERATIONS=2         # self-reflection loopbacks
OBSERVABILITY_ENABLED=true          # log LLM calls to data/llm_calls.jsonl
