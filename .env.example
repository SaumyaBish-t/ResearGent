# =============================================================================
# ResearGent — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the keys for the providers you want to use.
# You only need ONE provider to get started. The system picks whichever is configured.
#
# Priority order if multiple are set: NVIDIA > GROQ > OLLAMA
# Override explicitly with: PRIMARY_PROVIDER=nvidia|groq|ollama
# =============================================================================


# ---- NVIDIA NIM (build.nvidia.com) ------------------------------------------
# Free tier with ~1000 credits. Excellent reasoning models + embeddings.
# Get a key: https://build.nvidia.com  →  any model page  →  "Get API Key"
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model assignments per "tier" — change these to test different models.
NVIDIA_MODEL_REASONING=meta/llama-3.3-70b-instruct
NVIDIA_MODEL_FAST=meta/llama-3.1-8b-instruct
NVIDIA_MODEL_EMBED=nvidia/nv-embed-v1


# ---- Groq (console.groq.com) ------------------------------------------------
# Free tier with generous rate limits. FASTEST inference available — perfect
# for the Critic/Grader agents that run many times per query.
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

GROQ_MODEL_REASONING=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
# Groq does not currently host embedding models — falls back to other provider.


# ---- Ollama (local) ---------------------------------------------------------
# Fully local, no API key needed. Install: https://ollama.com
# Then pull models:   ollama pull llama3.1:8b   &&   ollama pull nomic-embed-text
# Good for 6–12GB VRAM GPUs. For reasoning on 8GB VRAM use 8B models only.
OLLAMA_BASE_URL=http://localhost:11434/v1

OLLAMA_MODEL_REASONING=llama3.1:8b
OLLAMA_MODEL_FAST=llama3.1:8b
OLLAMA_MODEL_EMBED=nomic-embed-text


# ---- Routing override -------------------------------------------------------
# Optional. Force a specific provider regardless of which keys are set.
# Leave blank for auto-detect (NVIDIA > GROQ > OLLAMA).
PRIMARY_PROVIDER=

# Optional per-tier override — useful for mixing providers
# (e.g. heavy reasoning on NVIDIA, fast judgments on Groq).
# REASONING_PROVIDER=nvidia
# FAST_PROVIDER=groq
# EMBED_PROVIDER=nvidia
