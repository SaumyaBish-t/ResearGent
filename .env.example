# =============================================================================
# ResearGent — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in keys for any provider(s) you want.
# You only need ONE provider to get started. The system picks whichever is
# configured, in this priority order:
#
#   cerebras  >  nvidia  >  groq  >  openrouter  >  ollama
#
# Override the auto-pick globally with PRIMARY_PROVIDER=<name>, or per-tier
# with REASONING_PROVIDER, FAST_PROVIDER, EMBED_PROVIDER.
# =============================================================================


# ---- Cerebras (cloud.cerebras.ai) -------------------------------------------
# FASTEST cloud inference on the planet — ~1000+ tokens/sec on huge models.
# Free tier: 1,000,000 tokens/day, 30 RPM. Perfect for agent loops where many
# sequential LLM calls compound into long wall-clock times.
# Get a key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Available free models on Cerebras (May 2026):
#   - qwen-3-235b-a22b-instruct-2507     (huge MoE, recommended for reasoning)
#   - llama-3.3-70b                      (great all-rounder)
#   - llama3.1-8b                        (fastest, perfect for the FAST tier)
#   - gpt-oss-120b                       (OpenAI's open-weights model)
#   - deepseek-r1-distill-llama-70b      (reasoning specialist)
CEREBRAS_MODEL_REASONING=qwen-3-235b-a22b-instruct-2507
CEREBRAS_MODEL_FAST=llama3.1-8b
CEREBRAS_MODEL_TOOL=qwen-3-235b-a22b-instruct-2507


# ---- NVIDIA NIM (build.nvidia.com) ------------------------------------------
# 80+ models — including MiniMax M2.7, Kimi 2.5, DeepSeek 3.2, GLM 5.1,
# GPT-OSS-120B, Nemotron, and the only top-tier embedder in our stack.
# Get a key: https://build.nvidia.com  →  any model page  →  "Get API Key"
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

NVIDIA_MODEL_REASONING=meta/llama-3.3-70b-instruct
NVIDIA_MODEL_FAST=meta/llama-3.1-8b-instruct
NVIDIA_MODEL_TOOL=meta/llama-3.3-70b-instruct
NVIDIA_MODEL_EMBED=nvidia/nv-embed-v1
# Other NVIDIA reasoning options (some require account whitelisting):
#   - nvidia/llama-3.1-nemotron-70b-instruct   (NVIDIA fine-tune; gated on some accounts)
#   - deepseek-ai/deepseek-r1                  (reasoning specialist; outputs <think>)
#   - qwen/qwen2.5-72b-instruct                (great for structured output)
#   - minimax/minimax-m2.7                     (230B MoE, 10B active)
#   - moonshotai/kimi-k2-instruct              (very strong long-context)


# ---- Groq (console.groq.com) ------------------------------------------------
# 315 TPS on Llama 70B — the speed king for the FAST tier (Critic / Grader).
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

GROQ_MODEL_REASONING=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
# Groq's GPT-OSS-120B is the best free-tier tool-calling model available.
GROQ_MODEL_TOOL=openai/gpt-oss-120b
# Groq does not host embedding models.


# ---- OpenRouter (openrouter.ai) ---------------------------------------------
# Meta-aggregator — one OpenAI-compatible endpoint fronting 200+ models.
# Free models carry the ":free" suffix. Free tier: 50 req/day, 20 RPM
# (1000/day if you ever deposit $10 — one-time, not consumed).
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

OPENROUTER_MODEL_REASONING=deepseek/deepseek-r1:free
OPENROUTER_MODEL_FAST=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL_TOOL=qwen/qwen3-235b-a22b:free
OPENROUTER_MODEL_EMBED=nvidia/nv-embed-v1
# Other free models worth trying:
#   - minimax/minimax-m2.5:free             (230B MoE, agentic-tuned)
#   - stepfun/step-3.5-flash:free           (196B sparse MoE, fast + reliable)
#   - qwen/qwen3-235b-a22b:free             (huge Qwen, strong reasoning)
#   - google/gemini-2.5-pro-exp:free        (1M context — great for synthesis)
#   - nvidia/llama-3.1-nemotron-70b-instruct:free
#   - meta-llama/llama-4-maverick:free
# Optional dashboard attribution:
OPENROUTER_APP_URL=https://github.com/SaumyaBish-t/ResearGent
OPENROUTER_APP_NAME=ResearGent


# ---- Ollama (local) ---------------------------------------------------------
# Fully local, no API key. Install: https://ollama.com
# Then pull models:   ollama pull llama3.1:8b   &&   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_REASONING=llama3.1:8b
OLLAMA_MODEL_FAST=llama3.1:8b
OLLAMA_MODEL_TOOL=llama3.1:8b
OLLAMA_MODEL_EMBED=nomic-embed-text


# ---- Routing ----------------------------------------------------------------
# Leave blank to use the auto-priority order shown at the top of this file.
PRIMARY_PROVIDER=

# RECOMMENDED per-tier routing — measured on real smoke tests, May 2026.
# Leave blank to use auto-priority (cerebras > nvidia > groq > openrouter > ollama).
#
# Why these defaults:
#   REASONING -> cerebras   Qwen3-235B runs at ~1.2s on Cerebras (vs 50s for
#                           MiniMax M2.7 on NVIDIA free). Same param class,
#                           dramatically more reliable. Cascade falls back
#                           through NVIDIA/Groq/OpenRouter on congestion.
#   FAST      -> groq       llama-3.1-8b-instant ~500ms. Most reliable free
#                           tier for the Critic agent (10-20x calls/query).
#   TOOL      -> groq       GPT-OSS-120B is the best free tool-caller right
#                           now, sub-second on Groq.
#   EMBED     -> nvidia     nv-embed-v1 — top MTEB scores, only top embedder
#                           on free tiers.
#
# Premium models to consider (slow but high quality — best for Phase 6 one-shot
# report synthesis, not for inside the agent loop):
#   - minimaxai/minimax-m2.7  (230B MoE, 10B active, agentic-tuned)
#   - deepseek/deepseek-v4-flash:free  (284B MoE, 1M context — but free pool
#                                       is heavily rate-limited / 429s common)
REASONING_PROVIDER=cerebras
FAST_PROVIDER=groq
TOOL_PROVIDER=groq
EMBED_PROVIDER=nvidia


# ---- Cascade fallback -------------------------------------------------------
# When the primary provider returns a transient error (429 / 5xx / timeout),
# the system automatically retries on the next configured provider in priority
# order. Critical for surviving free-tier rate limits in long agent loops.
# Set to false to surface raw errors (useful for debugging).
CASCADE_FALLBACK_ENABLED=true


# ---- Observability ----------------------------------------------------------
# Every chat() / embed() call appends a JSONL record with provider, model,
# latency, tokens, and cascade depth. View aggregates with `researgent stats`.
OBSERVABILITY_ENABLED=true
OBSERVABILITY_LOG_PATH=data/llm_calls.jsonl
