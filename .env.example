# =============================================================================
# ResearGent — Environment Configuration
# =============================================================================
# Copy this file to `.env` and bring your own models.
#
# ResearGent routes every LLM call by CAPABILITY TIER. The simplest setup is to
# point each tier at ANY OpenAI-compatible endpoint with three values:
#   <TIER>_API_KEY   <TIER>_BASE_URL   <TIER>_MODEL
#
#   • REASONING — Planner, Generator, Reflector  (your strongest model)
#   • FAST      — Critic, Rewriter               (low-latency / cheap; called
#                                                  many times per query)
#   • TOOL      — function / structured-output calls
#   • EMBED     — retrieval embeddings           (required for local search)
#
# Any OpenAI-compatible base URL works, e.g.:
#   OpenAI       https://api.openai.com/v1
#   OpenRouter   https://openrouter.ai/api/v1
#   Groq         https://api.groq.com/openai/v1
#   NVIDIA NIM   https://integrate.api.nvidia.com/v1
#   Cerebras     https://api.cerebras.ai/v1
#   Ollama       http://localhost:11434/v1     (local; API key can be anything)
#   vLLM / LM Studio / any local server: its own /v1 URL
# =============================================================================


# -----------------------------------------------------------------------------
# 1) LLM TIERS  — set a key + endpoint + model for each (your choice of model)
# -----------------------------------------------------------------------------
# You can point every tier at the same provider, or mix providers per tier
# (e.g. a big model for REASONING, a cheap fast one for FAST).

# --- Reasoning (Planner / Generator / Reflector) ---
REASONING_API_KEY=
REASONING_BASE_URL=
REASONING_MODEL=

# --- Fast / Critic (Critic / Rewriter) ---
FAST_API_KEY=
FAST_BASE_URL=
FAST_MODEL=

# --- Tool calling ---
TOOL_API_KEY=
TOOL_BASE_URL=
TOOL_MODEL=

# --- Embeddings (required for local retrieval) ---
# Local example with Ollama:
#   EMBED_API_KEY=ollama
#   EMBED_BASE_URL=http://localhost:11434/v1
#   EMBED_MODEL=nomic-embed-text        # after: `ollama pull nomic-embed-text`
EMBED_API_KEY=
EMBED_BASE_URL=
EMBED_MODEL=


# -----------------------------------------------------------------------------
# 1a) OLLAMA CLOUD PRESET  (recommended for fast, tool-capable research)
# -----------------------------------------------------------------------------
# Ollama Cloud is OpenAI-compatible. Get a key at https://ollama.com/settings/keys
# Endpoint:  https://ollama.com/v1
#
# Recommended tier mapping for ResearGent — strong reasoning, fast critique,
# best-in-class tool calling:
#
#   REASONING_API_KEY=<your-ollama-cloud-key>
#   REASONING_BASE_URL=https://ollama.com/v1
#   REASONING_MODEL=gpt-oss:120b        # planner / generator / reflector
#
#   FAST_API_KEY=<your-ollama-cloud-key>
#   FAST_BASE_URL=https://ollama.com/v1
#   FAST_MODEL=gpt-oss:20b              # critic / rewriter (low-latency)
#
#   TOOL_API_KEY=<your-ollama-cloud-key>
#   TOOL_BASE_URL=https://ollama.com/v1
#   TOOL_MODEL=qwen3-coder:480b         # best JSON / function calling
#
# Embeddings caveat: Ollama Cloud does NOT host embedding models.
# Keep EMBED on local Ollama (or another provider):
#
#   EMBED_API_KEY=ollama
#   EMBED_BASE_URL=http://localhost:11434/v1
#   EMBED_MODEL=nomic-embed-text        # after: `ollama pull nomic-embed-text`


# -----------------------------------------------------------------------------
# 2) RATE-LIMIT FALLBACKS  (optional — free tiers hit 429s)
# -----------------------------------------------------------------------------
# When enabled, a transient failure (429 / 5xx / timeout) on a tier rolls over
# to the next configured option automatically.
CASCADE_FALLBACK_ENABLED=true
#
# To give a tier a fallback, add one or more PROVIDER SLOTS below. Each slot is
# an OpenAI-compatible provider with an API key + per-tier models; configured
# slots are appended after your tier-direct endpoint as automatic fallbacks.
#
# Built-in slots: cerebras | nvidia | groq | openrouter | ollama
#
#   CEREBRAS_API_KEY=
#   CEREBRAS_MODEL_REASONING=
#   CEREBRAS_MODEL_FAST=
#   CEREBRAS_MODEL_TOOL=
#
#   GROQ_API_KEY=
#   GROQ_MODEL_REASONING=
#   GROQ_MODEL_FAST=
#   GROQ_MODEL_TOOL=
#
#   NVIDIA_API_KEY=
#   NVIDIA_MODEL_REASONING=
#   NVIDIA_MODEL_FAST=
#   NVIDIA_MODEL_TOOL=
#   NVIDIA_MODEL_EMBED=
#
#   OPENROUTER_API_KEY=
#   OPENROUTER_MODEL_REASONING=
#   OPENROUTER_MODEL_FAST=
#   OPENROUTER_MODEL_TOOL=
#   OPENROUTER_MODEL_EMBED=
#
#   OLLAMA_BASE_URL=http://localhost:11434/v1
#   OLLAMA_MODEL_REASONING=
#   OLLAMA_MODEL_FAST=
#   OLLAMA_MODEL_TOOL=
#   OLLAMA_MODEL_EMBED=
#
# Optional: pin an EXACT fallback order per tier (comma-separated slot names).
# Example — Critic hops Groq → Cerebras → OpenRouter on a rate limit:
#   FAST_CASCADE=groq,cerebras,openrouter
#   REASONING_CASCADE=nvidia,openrouter,ollama
#   TOOL_CASCADE=groq,cerebras


# -----------------------------------------------------------------------------
# 3) WEB SEARCH FALLBACK  (when local + academic evidence is insufficient)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=          # optional — agent-tuned web search (https://tavily.com)
SERPER_API_KEY=          # optional — Google SERP (https://serper.dev)
# DuckDuckGo needs no key and is the guaranteed final fallback.
# WEB_SEARCH_CASCADE=tavily,serper,duckduckgo


# -----------------------------------------------------------------------------
# 4) ACADEMIC API  (arXiv + Semantic Scholar paper discovery)
# -----------------------------------------------------------------------------
# Optional — works without a key, just slower. A key removes most 429s.
SEMANTIC_SCHOLAR_API_KEY=


# -----------------------------------------------------------------------------
# 5) KNOWLEDGE BASE  (where cited answers are saved)
# -----------------------------------------------------------------------------
# Folder of plain .md files (works with VS Code, Obsidian, Logseq, vim, …).
# Defaults to ./notes if left blank.
# NOTES_FOLDER_PATH=
OBSIDIAN_OUTPUT_FOLDER=ResearGent

# Auto-save runs that clear the confidence gate.  high | medium | low | always
AUTO_SAVE_TO_NOTES=true
AUTO_SAVE_MIN_CONFIDENCE=medium


# -----------------------------------------------------------------------------
# 6) FRONTEND + TUNABLES  (sensible defaults — override only if needed)
# -----------------------------------------------------------------------------
# Browser origins allowed to call the API (the Next.js dev server is :3000).
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

CRAG_MAX_REWRITES=2                 # query rewrites before web fallback
GRAPH_EXPANSION_ENABLED=true        # 1-hop note-link expansion at retrieval
REFLECTION_MAX_ITERATIONS=2         # self-reflection loopbacks
OBSERVABILITY_ENABLED=true          # log LLM calls to data/llm_calls.jsonl
