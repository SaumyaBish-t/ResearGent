# Environments
.env
.env.local
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# uv
.uv/

# Personal notes — your knowledge base is YOURS, never committed.
# We ship only the README + examples; everything else is excluded.
notes/*
!notes/README.md
!notes/_examples/
!notes/_examples/**
!notes/concepts/
!notes/concepts/.gitkeep
!notes/projects/
!notes/projects/.gitkeep
!notes/sources/
!notes/sources/.gitkeep

# Data — never commit corpora, vector stores, or downloaded papers
data/papers/*
!data/papers/.gitkeep
data/chroma_db/
data/store/
data/bm25_idx/
data/agent_state/
data/cache/
data/eval/
data/llm_calls.jsonl
*.sqlite
*.db

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
