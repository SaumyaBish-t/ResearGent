# Environments
.env
.env.local
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# uv
.uv/

# Personal notes — your knowledge base is YOURS, never committed.
# We ship only the README + examples; everything else is excluded.
notes/*
!notes/README.md
!notes/_examples/
!notes/_examples/**
!notes/concepts/
!notes/concepts/.gitkeep
!notes/projects/
!notes/projects/.gitkeep
!notes/sources/
!notes/sources/.gitkeep

# Data — never commit corpora, vector stores, or downloaded papers
# Phase 16: consolidated per-domain layout. Each domain owns one folder
# under data/ with three subfolders (papers/, abstract_notes/,
# research_data/). Track the directory shape so a fresh clone has the
# topology ready for `researgent ingest-domains` / `seed`; ignore content.
data/*
!data/.gitkeep
!data/agentic_ai/
!data/quant_finance/
!data/time_series/
data/agentic_ai/*
data/quant_finance/*
data/time_series/*
!data/agentic_ai/papers/
!data/agentic_ai/abstract_notes/
!data/agentic_ai/research_data/
!data/quant_finance/papers/
!data/quant_finance/abstract_notes/
!data/quant_finance/research_data/
!data/time_series/papers/
!data/time_series/abstract_notes/
!data/time_series/research_data/
data/agentic_ai/papers/*
data/agentic_ai/abstract_notes/*
data/agentic_ai/research_data/*
data/quant_finance/papers/*
data/quant_finance/abstract_notes/*
data/quant_finance/research_data/*
data/time_series/papers/*
data/time_series/abstract_notes/*
data/time_series/research_data/*
!data/agentic_ai/papers/.gitkeep
!data/agentic_ai/abstract_notes/.gitkeep
!data/agentic_ai/research_data/.gitkeep
!data/quant_finance/papers/.gitkeep
!data/quant_finance/abstract_notes/.gitkeep
!data/quant_finance/research_data/.gitkeep
!data/time_series/papers/.gitkeep
!data/time_series/abstract_notes/.gitkeep
!data/time_series/research_data/.gitkeep
# Legacy paths kept ignored so any leftover stuff doesn't get committed
# during migration.
data/papers/
data/notes/
data/chroma_db/
data/store/
# Phase 12: raw bytes by content_hash, never committed
data/storage/
data/bm25_idx/
data/agent_state/
data/cache/
data/eval/
data/llm_calls.jsonl
*.sqlite
*.db

