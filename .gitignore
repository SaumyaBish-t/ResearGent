# Environments
.env
.env.local
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# uv
.uv/

# Personal notes — your knowledge base is YOURS, never committed.
# We ship only the README + examples; everything else is excluded.
notes/*
!notes/README.md
!notes/_examples/
!notes/_examples/**
!notes/concepts/
!notes/concepts/.gitkeep
!notes/projects/
!notes/projects/.gitkeep
!notes/sources/
!notes/sources/.gitkeep

# Data — never commit corpora, vector stores, or downloaded papers
data/papers/*
!data/papers/.gitkeep
# Phase 15: preserve the three per-domain ingest roots in git so a fresh
# clone has the topology ready for `researgent ingest-domains` / `seed`.
# The directories are tracked; their PDF/MD contents are not.
!data/papers/agentic_ai/
!data/papers/quant_finance/
!data/papers/time_series/
data/papers/agentic_ai/*
data/papers/quant_finance/*
data/papers/time_series/*
!data/papers/agentic_ai/.gitkeep
!data/papers/quant_finance/.gitkeep
!data/papers/time_series/.gitkeep
data/chroma_db/
data/store/
data/bm25_idx/
data/agent_state/
data/cache/
data/eval/
data/llm_calls.jsonl
*.sqlite
*.db

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
